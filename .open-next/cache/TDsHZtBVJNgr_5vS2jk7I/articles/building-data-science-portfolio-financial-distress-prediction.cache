Name\":\"mono text-[12px]\",\"style\":{\"color\":\"var(--ink-faint)\"},\"children\":[\"Apr 2026\",\" · \",\"1 min read\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 font-bold\",\"style\":{\"fontSize\":\"clamp(28px,4vw,44px)\",\"lineHeight\":1.12,\"letterSpacing\":\"-0.03em\"},\"children\":\"Building a Data Science Portfolio Around Financial Distress Prediction\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-[16px]\",\"style\":{\"lineHeight\":1.6,\"color\":\"var(--ink-dim)\"},\"children\":\"A reflection on turning a thesis topic into a portfolio-ready data science project.\"}],[\"$\",\"div\",null,{\"className\":\"mt-6 aspect-[16/9] w-full\",\"style\":{\"position\":\"relative\",\"overflow\":\"hidden\",\"borderRadius\":15},\"children\":[\"$\",\"$L1c\",null,{\"src\":\"https://cms.daffa.me/uploads/financialdistress_39c845d325.jpg\",\"alt\":\"Financial disstress illustration\",\"fill\":true,\"sizes\":\"(max-width: 860px) 100vw, 820px\",\"priority\":true,\"style\":{\"objectFit\":\"cover\"},\"fallback\":[\"$\",\"div\",null,{\"role\":\"img\",\"aria-label\":\"Building a Data Science Portfolio Around Financial Distress Prediction cover\",\"className\":\"absolute inset-0 h-full w-full\",\"style\":{\"background\":\"linear-gradient(135deg, color-mix(in srgb, var(--teal) 26%, var(--surface)), color-mix(in srgb, var(--sky) 22%, var(--surface)))\",\"borderRadius\":15}}]}]}],[\"$\",\"article\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1d\",null,{\"content\":[{\"type\":\"paragraph\",\"children\":[{\"text\":\"My current main data science project focuses on financial distress prediction for Indonesian public companies. Instead of treating the thesis only as an academic requirement, I want to structure it as a portfolio project that clearly shows the full data science workflow: problem framing, data preparation, exploratory analysis, modeling, evaluation, and communication.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"children\":[{\"text\":\"The main challenge is not only building a model, but also explaining why the model matters. Financial distress prediction sits at the intersection of finance, business, and machine learning. This makes it useful for showing both technical and analytical thinking.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"children\":[{\"text\":\"For the portfolio version, I plan to present the project through notebooks, visualizations, model comparison tables, and a concise explanation of the business context.\",\"type\":\"text\"}]}]}]}],[\"$\",\"div\",null,{\"className\":\"mt-8 flex flex-wrap gap-[7px]\",\"children\":[[\"$\",\"span\",\"data science\",{\"className\":\"chip mono px-[9px] py-1 text-[11px]\",\"style\":{\"borderRadius\":8},\"children\":[\"#\",\"data science\"]}],[\"$\",\"span\",\"machine learning\",{\"className\":\"chip mono px-[9px] py-1 text-[11px]\",\"style\":{\"borderRadius\":8},\"children\":[\"#\",\"machine learning\"]}],[\"$\",\"span\",\"financial distress\",{\"className\":\"chip mono px-[9px] py-1 text-[11px]\",\"style\":{\"borderRadius\":8},\"children\":[\"#\",\"financial distress\"]}],[\"$\",\"span\",\"portfolio\",{\"className\":\"chip mono px-[9px] py-1 text-[11px]\",\"style\":{\"borderRadius\":8},\"children\":[\"#\",\"portfolio\"]}],[\"$\",\"span\",\"thesis\",{\"className\":\"chip mono px-[9px] py-1 text-[11px]\",\"style\":{\"borderRadius\":8},\"children\":[\"#\",\"thesis\"]}]]}],false]}]\n1e:I[27201,[\"/_next/static/chunks/2miu-xgxthh4m.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"IconMark\"]\n15:null\n1a:[[\"$\",\"title\",\"0\",{\"children\":\"Building a Data Science Portfolio Around Financial Distress Prediction\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"A reflection on turning a thesis topic into a portfolio-ready data science project.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"canonical\",\"href\":\"https://daffa.me/articles/building-data-science-portfolio-financial-distress-prediction\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:title\",\"content\":\"B