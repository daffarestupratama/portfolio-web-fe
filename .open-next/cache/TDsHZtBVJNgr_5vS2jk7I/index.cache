906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null}],\"logo\":{\"url\":\"https://cms.daffa.me/uploads/logo_UI_fd34e132a2.png\",\"alt\":\"Universitas Indonesia, Faculty of Computer Science\",\"width\":1396,\"height\":1526}},{\"id\":\"p0jgq6680zgvafj9u3rwbdt8\",\"category\":\"education\",\"organization\":\"SMA Negeri 1 Yogyakarta\",\"initials\":\"SNY\",\"role\":\"Student\",\"dateRange\":\"'18–'21\",\"description\":\"Completed senior high school at SMA Negeri 1 Yogyakarta. During this period, I joined Teladan Robotic Team, participated in POH Al Uswah, competed in KSN Informatics/Computer Science up to the provincial level twice, and ranked 17th overall in report-card performance across the cohort.\",\"startDate\":\"2018-07-01\",\"endDate\":\"2021-06-30\",\"isCurrent\":false,\"gallery\":[],\"logo\":{\"url\":\"https://cms.daffa.me/uploads/logo_teladan_e8c5f198ec.png\",\"alt\":\"Logo SMA Negeri 1 Teladan Yogyakarta\",\"width\":165,\"height\":300}}],\"organization\":[{\"id\":\"bnp2cweoeoei5figz7kiu9n5\",\"category\":\"organization\",\"organization\":\"COMPFEST\",\"initials\":\"CO\",\"role\":\"Head of Business Development & Startup Academy Staff\",\"dateRange\":\"'22–'23\",\"description\":\"Contributed to COMPFEST for two consecutive years across program and business functions. In 2022, I served as a Startup Academy staff member, supporting speaker outreach, participant liaison, speaker liaison, academy class hosting, and mentoring session operations. In 2023, I continued as Head of Business Development, managing a division responsible for revenue-generating initiatives, official merchandise, and participant souvenirs. I also initiated documentation and management structures to make the division’s workflow more organized and scalable.\",\"startDate\":\"2022-01-01\",\"endDate\":\"2023-12-31\",\"isCurrent\":false,\"gallery\":[],\"logo\":null},{\"id\":\"bkjalr4mjtleyqska8fv8b4z\",\"category\":\"organization\",\"organization\":\"Educare CSUI\",\"initials\":\"EC\",\"role\":\"Staff of Job Fair\",\"dateRange\":\"'22–'23\",\"description\":\"Served in the Job Fair division of Educare CSUI, a career-related event at the Faculty of Computer Science, Universitas Indonesia. Responsibilities included reaching out to HR representatives, collecting and curating job opportunities for the event, and supporting operational execution during the job fair sessions.\",\"startDate\":\"2022-01-01\",\"endDate\":\"2023-06-01\",\"isCurrent\":false,\"gallery\":[],\"logo\":null},{\"id\":\"kns0oy84mt4aqzlntfo0t46p\",\"category\":\"organization\",\"organization\":\"BEM Faculty of Computer Science, Universitas Indonesia\",\"initials\":\"BFC\",\"role\":\"Staff of Knowledge and Academic Affairs Division\",\"dateRange\":\"'22\",\"description\":\"Contributed to the faculty student executive board in the knowledge and academic affairs division. This experience strengthened my ability to work in structured student organizations, communicate ideas, and support programs related to academic and intellectual development.\",\"startDate\":\"2022-01-01\",\"endDate\":\"2022-12-31\",\"isCurrent\":false,\"gallery\":[],\"logo\":null},{\"id\":\"ivffli7kcl7xa2uuyl9d3b3k\",\"category\":\"organization\",\"organization\":\"Teladan Robotic Team\",\"initials\":\"TRT\",\"role\":\"Secretary / Member\",\"dateRange\":\"'18–'20\",\"description\":\"Joined the school robotics extracurricular community, gaining early exposure to technology, problem solving, teamwork, and engineering-oriented thinking.\",\"startDate\":\"2018-07-01\",\"endDate\":\"2020-06-30\",\"isCurrent\":false,\"gallery\":[],\"logo\":null}],\"others\":[]}}]\n16:[\"$\",\"section\",null,{\"className\":\"relative z-[3] flex justify-center px-[22px] pt-[46px] pb-2.5\",\"children\":[\"$\",\"div\",null,{\"className\":\"w-full max-w-[1180px]\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-[22px] flex flex-wrap items-end justify-between gap-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-bold\",\"style\":{\"fontSize\":\"clamp(26px,3vw,38px)\",\"letterSpacing\":\"-0.03em\"},\"children\":\"Selected projects\"}],[\"$\",\"$L10\",null,{\"href\":\"/projects\",\"className\":\"glass-pill gap-[7px] px-[17px] py-[9px] text-[13.5px] font-semibold\",\"children\":[\"All projects\",[\"$\",\"svg\",null,{\"width\":\"15\",\"height\":\"15\",\"viewBox\":\"0 0 24 24\",\"strokeWidth\":\"2\",\"fill\":\"none\",\"stroke\":\"currentColor\",\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"aria-hidden\":true,\"children\":[[\"$\",\"line\",null,{\"x1\":\"5\",\"y1\":\"12\",\"x2\":\"19\",\"y2\":\"12\"}],[\"$\",\"polyline\",null,{\"points\":\"12 5 19 12 12 19\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 gap-[18px] md:grid-cols-2\",\"children\":[[\"$\",\"$L1d\",\"u37ky6tkj1pa22ul3zbngw75\",{\"project\":{\"id\":\"u37ky6tkj1pa22ul3zbngw75\",\"slug\":\"financial-distress-prediction-indonesia-public-companies\",\"title\":\"Financial Distress Prediction for Indonesian Public Companies\",\"summary\":\"A machine learning project focused on predicting financial distress among Indonesian public companies using financial indicators and structured modeling workflows.\",\"year\":\"2026\",\"projectType\":\"machine_learning\",\"techStack\":[\"Python\",\"Jupyter Notebook\",\"Pandas\",\"NumPy\",\"Scikit-learn\",\"Matplotlib\",\"PostgreSQL\",\"Financial Analysis\"],\"coverImage\":null,\"githubUrl\":\"$undefined\",\"dashboardUrl\":\"$undefined\",\"liveDemoUrl\":\"$undefined\"}}],[\"$\",\"$L1d\",\"s6lc