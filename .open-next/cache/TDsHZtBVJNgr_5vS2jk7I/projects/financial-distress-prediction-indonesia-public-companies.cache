"M845 393V109H904L915 118V150L957 109H1066V174H959L915 212V393H845Z\" style=\"fill:var(--ink)\"></path><path d=\"M0 393L173 13H250L78 393H0Z\" style=\"fill:var(--accent)\"></path></svg><span aria-hidden=\"true\" class=\"w-2 rounded-xs\" style=\"height:18px;background:var(--accent);animation:blink 1.15s steps(1) infinite\"></span></a><div class=\"hidden items-center gap-0.5 md:flex\"><a class=\"nav-link\" data-active=\"false\" href=\"/\">Home</a><a class=\"nav-link\" data-active=\"false\" href=\"/projects\">Projects</a><a class=\"nav-link\" data-active=\"false\" href=\"/articles\">Articles</a><a class=\"nav-link\" data-active=\"false\" href=\"/tours\">Tours</a><a class=\"nav-link\" data-active=\"false\" href=\"/about\">About</a></div><div class=\"flex items-center gap-2\"><a aria-label=\"mkdir\" class=\"glass-pill mono h-10 shrink-0 gap-1.5 px-2.5 text-[13px] font-medium sm:px-3.5\" style=\"color:var(--ink)\" href=\"/mkdir\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" stroke-width=\"1.9\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" style=\"color:var(--accent-ink)\"><polyline points=\"4 17 10 11 4 5\"></polyline><line x1=\"12\" y1=\"19\" x2=\"20\" y2=\"19\"></line></svg><span class=\"hidden sm:inline\"><span style=\"color:var(--accent-ink)\"></span>mkdir</span></a><button type=\"button\" aria-label=\"Switch to dark theme\" class=\"glass-icon-btn flex h-10 w-10 shrink-0\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" stroke-width=\"1.8\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"></path></svg></button><div class=\"md:hidden\"><button type=\"button\" aria-label=\"Open menu\" aria-expanded=\"false\" aria-controls=\"mobile-nav-panel\" class=\"glass-icon-btn flex h-10 w-10 shrink-0\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" stroke-width=\"1.8\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"></line><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"></line><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"></line></svg></button></div></div></nav></div></div><!--$--><!--$--><main class=\"relative z-[3] mx-auto w-full max-w-[860px] px-[22px] pt-28 pb-16 sm:pt-32\"><a class=\"mono inline-flex items-center gap-1.5 text-[12.5px] transition-colors hover:text-(--accent-ink)\" style=\"color:var(--ink-dim)\" href=\"/projects\"><svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" stroke-width=\"2\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" style=\"transform:rotate(180deg)\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg>All projects</a><div class=\"mt-5 flex flex-wrap items-center gap-2.5\"><span class=\"badge\" style=\"color:color-mix(in srgb, var(--sky) 52%, var(--ink));background:color-mix(in srgb, var(--sky) 15%, transparent);border-color:color-mix(in srgb, var(--sky) 32%, transparent)\">Machine Learning</span><span class=\"chip rounded-full px-2.5 py-1 text-[11.5px]\">In Progress</span><span class=\"mono text-[12px]\" style=\"color:var(--ink-faint)\">2026</span></div><h1 class=\"mt-3 font-bold\" style=\"font-size:clamp(28px,4vw,44px);line-height:1.1;letter-spacing:-0.03em\">Financial Distress Prediction for Indonesian Public Companies</h1><p class=\"mt-4 text-[16px]\" style=\"line-height:1.6;color:var(--ink-dim)\">A machine learning project focused on predicting financial distress among Indonesian public companies using financial indicators and structured modeling workflows.</p><div role=\"img\" aria-label=\"Financial Distress Prediction for Indonesian Public Companies cover\" class=\"mt-6 aspect-video w-full\" style=\"background:linear-gradient(135deg, color-mix(in srgb, var(--accent) 26%, var(--surface)), color-mix(in srgb, var(--green) 22%, var(--surface)));border-radius:15px\"></div><div class=\"mt-6 flex flex-wrap gap-[7px]\"><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">Python</span><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">Jupyter Notebook</span><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">Pandas</span><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">NumPy</span><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">Scikit-learn</span><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">Matplotlib</span><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">PostgreSQL</span><span class=\"chip mono px-[9px] py-1 text-[11px]\" style=\"border-radius:8px\">Financial Analysis</span></div><section><h2 class=\"mt-10 mb-3 text-[22px] font-bold\" style=\"letter-spacing:-0.02em\">Problem</h2><p class=\"text-[15.5px]\" style=\"line-height:1.75;color:var(--ink)\">Financial distress prediction is important for investors, analysts, and stakeholders because early warning signals can support better decision-making.</p></section><section><h2 class=\"mt-10 mb-3 text-[22px] font-bold\" style=\"letter-spacing:-0.02em\">Approach</h2><p class=\"mt-4 text-[15.5px] first:mt-0\" style=\"line-height:1.75;color:var(--ink)\">This project uses a notebook-based data science workflow, starting from data preparation, feature engineering, exploratory data analysis, model training, evaluation, and interpretation.</p></section><section><h2 class=\"mt-10 mb-3 text-[22px] font-bold\" style=\"letter-spacing:-0.02em\">Result</h2><p class=\"mt-4 text-[15.5px] first:mt-0\" style=\"line-height:1.75;color:var(--ink)\">The project is currently in progress as part of my thesis work. The expected output is a structured machine learning model comparison, clear evaluation metrics, and a portfolio-ready explanation of the data science process.</p></section><section><h2 class=\"mt-10 mb-3 text-[22px] font-bold\" style=\"letter-spacing:-0.02em\">Notebooks &amp; outputs</h2><div class=\"flex flex-col gap-3\"><div class=\"glass-card p-4\" style=\"border-radius:16px\"><div class=\"flex flex-wrap items-center gap-2.5\"><span class=\"badge\" style=\"color:var(--accent-ink);background:var(--chip);border-color:var(--chip-brd)\">Jupyter Notebook</span><h3 class=\"text-[15px] font-semibold\" style=\"letter-spacing:-0.01em\">Main Jupyter Notebook</h3></div><p class=\"mt-2 text-[13.5px]\" style=\"line-height:1.55;color:var(--ink-dim)\">Primary notebook containing the end-to-end workflow for data preparation, modeling, evaluation, and interpretation.</p></div><div class=\"glass-card p-4\" style=\"border-radius:16px\"><div class=\"flex flex-wrap items-center gap-2.5\"><span class=\"badge\" style=\"color:var(--accent-ink);background:var(--chip);border-color:var(--chip-brd)\">Dashboard</span><h3 class=\"text-[15px] font-semibold\" style=\"letter-spacing:-0.01em\">Model Evaluation Dashboard</h3></div><p class=\"mt-2 text-[13.5px]\" style=\"line-height:1.55;color:var(--ink-dim)\">Planned interactive dashboard for comparing model performance, feature importance, and prediction outputs.</p></div></div></section></main><!--$--><!--/$--><!--/$--><!--/$--><footer class=\"relative z-[3] flex justify-center px-[22px] pt-[30px] pb-11\"><div class=\"flex w-full max-w-[1180px] flex-wrap items-center justify-between gap-4 px-5 py-[18px] sm:px-[22px]\" style=\"border-radius:20px;background:var(--glass-bg);background-image:var(--glass-tint);backdrop-filter:blur(var(--glass-blur)) saturate(180%);border:1px solid var(--glass-brd);box-shadow:inset 0 1px 0 var(--glass-hi)\"><span class=\"text-[13px]\" style=\"color:var(--ink-faint)\">© 2026 Daffa Ilham Restupratama</span><span class=\"mono text-[11px]\" style=\"color:var(--ink-faint)\">Data · Business · Finance · Maps · Walking Tours</span