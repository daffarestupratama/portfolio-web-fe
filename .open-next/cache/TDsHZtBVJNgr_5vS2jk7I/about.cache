heet\",\"href\":\"/_next/static/chunks/2vnee9rqmfix3.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n17:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n1a:I[88265,[\"/_next/static/chunks/2miu-xgxthh4m.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/0g3rov4w115o0.js\"],\"StrapiBlocks\"]\n25:I[27201,[\"/_next/static/chunks/2miu-xgxthh4m.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"IconMark\"]\n11:[\"$\",\"main\",null,{\"className\":\"relative z-[3] pt-28 pb-16 sm:pt-32\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mx-auto w-full max-w-[820px] px-[22px]\",\"children\":[[\"$\",\"header\",null,{\"children\":[[\"$\",\"h1\",null,{\"className\":\"font-bold\",\"style\":{\"fontSize\":\"clamp(30px,4.5vw,50px)\",\"lineHeight\":1.05,\"letterSpacing\":\"-0.03em\"},\"children\":\"About Me\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-[16px]\",\"style\":{\"lineHeight\":1.62,\"color\":\"var(--ink-dim)\"},\"children\":\"I am an Information Systems student who enjoys connecting data, technology, business, and human-centered stories.\"}]]}],null,[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1a\",null,{\"content\":[{\"type\":\"paragraph\",\"children\":[{\"text\":\"Hi, I am Daffa Ilham Restupratama, an Information Systems student at the Faculty of Computer Science, Universitas Indonesia.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"children\":[{\"text\":\"My academic and professional interests sit at the intersection of data, technology, business, and communication. I enjoy working on structured problems: understanding the context, organizing information, building systems, and communicating the result clearly.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"children\":[{\"text\":\"My current main project is a machine learning project for predicting financial distress among Indonesian public companies. Through this project, I aim to develop not only technical modeling skills, but also the ability to explain data science work in a way that is useful for business and decision-making audiences.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"children\":[{\"text\":\"Outside academic work, I have been involved in student organizations and large-scale events such as COMPFEST, Educare CSUI, and BEM Fasilkom UI. These experiences helped me develop management, communication, documentation, and cross-functional coordination skills.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"children\":[{\"text\":\"I also have a personal interest in cities, public transport, history, local food, and hidden urban stories. That interest led me to design city and walking tour concepts for places such as Jakarta, Bogor, Tangerang, and Yogyakarta.\",\"type\":\"text\"}]}]}]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mt-10 mb-5 text-[22px] font-bold\",\"style\":{\"letterSpacing\":\"-0.02em\"},\"children\":\"Skills\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-col gap-6\",\"children\":[[\"$\",\"div\",\"programming_language\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"mono mb-2.5 text-[11px] tracking-[0.12em] uppercase\",\"style\":{\"color\":\"var(--ink-faint)\"},\"children\":\"Programming Language\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[\"$\",\"span\",\"HTML & CSS\",{\"className\":\"chip inline-flex items-center gap-2 px-3 py-1.5 text-[13px]\",\"style\":{\"borderRadius\":999,\"color\":\"var(--ink)\"},\"title\":\"Used for structuring and styling responsive web pages and portfolio interfaces.\",\"children\":[\"HTML & CSS\",[\"$\",\"span\",null,{\"className\":\"mono text-[10px] tracking-wide capitalize\",\"style\":{\"color\":\"var(--accent-ink)\"},\"children\":\"intermediate\"}]]}],[\"$\",\"span\",\"Python\",{\"className\":\"chip inline-flex items-center gap-2 px-3 py-1.5 text-[13px]\",\"style