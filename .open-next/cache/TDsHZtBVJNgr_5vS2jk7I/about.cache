caption\\\":null}],\\\"logo\\\":{\\\"url\\\":\\\"https://cms.daffa.me/uploads/logo_UI_fd34e132a2.png\\\",\\\"alt\\\":\\\"Universitas Indonesia, Faculty of Computer Science\\\",\\\"width\\\":1396,\\\"height\\\":1526}},{\\\"id\\\":\\\"p0jgq6680zgvafj9u3rwbdt8\\\",\\\"category\\\":\\\"education\\\",\\\"organization\\\":\\\"SMA Negeri 1 Yogyakarta\\\",\\\"initials\\\":\\\"SNY\\\",\\\"role\\\":\\\"Student\\\",\\\"dateRange\\\":\\\"'18–'21\\\",\\\"description\\\":\\\"Completed senior high school at SMA Negeri 1 Yogyakarta. During this period, I joined Teladan Robotic Team, participated in POH Al Uswah, competed in KSN Informatics/Computer Science up to the provincial level twice, and ranked 17th overall in report-card performance across the cohort.\\\",\\\"startDate\\\":\\\"2018-07-01\\\",\\\"endDate\\\":\\\"2021-06-30\\\",\\\"isCurrent\\\":false,\\\"gallery\\\":[],\\\"logo\\\":{\\\"url\\\":\\\"https://cms.daffa.me/uploads/logo_teladan_e8c5f198ec.png\\\",\\\"alt\\\":\\\"Logo SMA Negeri 1 Teladan Yogyakarta\\\",\\\"width\\\":165,\\\"height\\\":300}}],\\\"organization\\\":[{\\\"id\\\":\\\"bnp2cweoeoei5figz7kiu9n5\\\",\\\"category\\\":\\\"organization\\\",\\\"organization\\\":\\\"COMPFEST\\\",\\\"initials\\\":\\\"CO\\\",\\\"role\\\":\\\"Head of Business Development \\u0026 Startup Academy Staff\\\",\\\"dateRange\\\":\\\"'22–'23\\\",\\\"description\\\":\\\"Contributed to COMPFEST for two consecutive years across program and business functions. In 2022, I served as a Startup Academy staff member, supporting speaker outreach, participant liaison, speaker liaison, academy class hosting, and mentoring session operations. In 2023, I continued as Head of Business Development, managing a division responsible for revenue-generating initiatives, official merchandise, and participant souvenirs. I also initiated documentation and management structures to make the division’s workflow more organized and scalable.\\\",\\\"startDate\\\":\\\"2022-01-01\\\",\\\"endDate\\\":\\\"2023-12-31\\\",\\\"isCurrent\\\":false,\\\"gallery\\\":[],\\\"logo\\\":null},{\\\"id\\\":\\\"bkjalr4mjtleyqska8fv8b4z\\\",\\\"category\\\":\\\"organization\\\",\\\"organization\\\":\\\"Educare CSUI\\\",\\\"initials\\\":\\\"EC\\\",\\\"role\\\":\\\"Staff of Job Fair\\\",\\\"dateRange\\\":\\\"'22–'23\\\",\\\"description\\\":\\\"Served in the Job Fair division of Educare CSUI, a career-related event at the Faculty of Computer Science, Universitas Indonesia. Responsibilities included reaching out to HR representatives, collecting and curating job opportunities for the event, and supporting operational execution during the job fair sessions.\\\",\\\"startDate\\\":\\\"2022-01-01\\\",\\\"endDate\\\":\\\"2023-06-01\\\",\\\"isCurrent\\\":false,\\\"gallery\\\":[],\\\"logo\\\":null},{\\\"id\\\":\\\"kns0oy84mt4aqzlntfo0t46p\\\",\\\"category\\\":\\\"organization\\\",\\\"organization\\\":\\\"BEM Faculty of Computer Science, Universitas Indonesia\\\",\\\"initials\\\":\\\"BFC\\\",\\\"role\\\":\\\"Staff of Knowledge and Academic Affairs Division\\\",\\\"dateRange\\\":\\\"'22\\\",\\\"description\\\":\\\"Contributed to the faculty student executive board in the knowledge and academic affairs division. This experience strengthened my ability to work in structured student organizations, communicate ideas, and support programs related to academic and intellectual development.\\\",\\\"startDate\\\":\\\"2022-01-01\\\",\\\"endDate\\\":\\\"2022-12-31\\\",\\\"isCurrent\\\":false,\\\"gallery\\\":[],\\\"logo\\\":null},{\\\"id\\\":\\\"ivffli7kcl7xa2uuyl9d3b3k\\\",\\\"category\\\":\\\"organization\\\",\\\"organization\\\":\\\"Teladan Robotic Team\\\",\\\"initials\\\":\\\"TRT\\\",\\\"role\\\":\\\"Secretary / Member\\\",\\\"dateRange\\\":\\\"'18–'20\\\",\\\"description\\\":\\\"Joined the school robotics extracurricular community, gaining early exposure to technology, problem solving, teamwork, and engineering-oriented thinking.\\\",\\\"startDate\\\":\\\"2018-07-01\\\",\\\"endDate\\\":\\\"2020-06-30\\\",\\\"isCurre