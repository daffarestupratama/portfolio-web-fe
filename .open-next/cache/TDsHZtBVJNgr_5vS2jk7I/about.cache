rl\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"Foto Universitas Indonesia di sore hari.\",\"width\":1200,\"height\":675,\"caption\":\"Foto Universitas Indonesia di sore hari.\"},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null},{\"url\":\"https://cms.daffa.me/uploads/ui_bcb906f8b8.jpg\",\"alt\":\"\",\"width\":1200,\"height\":675,\"caption\":null}],\"logo\":{\"url\":\"https://cms.daffa.me/uploads/logo_UI_fd34e132a2.png\",\"alt\":\"Universitas Indonesia, Faculty of Computer Science\",\"width\":1396,\"height\":1526}},{\"id\":\"p0jgq6680zgvafj9u3rwbdt8\",\"category\":\"education\",\"organization\":\"SMA Negeri 1 Yogyakarta\",\"initials\":\"SNY\",\"role\":\"Student\",\"dateRange\":\"'18–'21\",\"description\":\"Completed senior high school at SMA Negeri 1 Yogyakarta. During this period, I joined Teladan Robotic Team, participated in POH Al Uswah, competed in KSN Informatics/Computer Science up to the provincial level twice, and ranked 17th overall in report-card performance across the cohort.\",\"startDate\":\"2018-07-01\",\"endDate\":\"2021-06-30\",\"isCurrent\":false,\"gallery\":[],\"logo\":{\"url\":\"https://cms.daffa.me/uploads/logo_teladan_e8c5f198ec.png\",\"alt\":\"Logo SMA Negeri 1 Teladan Yogyakarta\",\"width\":165,\"height\":300}}],\"organization\":[{\"id\":\"bnp2cweoeoei5figz7kiu9n5\",\"category\":\"organization\",\"organization\":\"COMPFEST\",\"initials\":\"CO\",\"role\":\"Head of Business Development & Startup Academy Staff\",\"dateRange\":\"'22–'23\",\"description\":\"Contributed to COMPFEST for two consecutive years across program and business functions. In 2022, I served as a Startup Academy staff member, supporting speaker outreach, participant liaison, speaker liaison, academy class hosting, and mentoring session operations. In 2023, I continued as Head of Business Development, managing a division responsible for revenue-generating initiatives, official merchandise, and participant souvenirs. I also initiated documentation and management structures to make the division’s workflow more organized and scalable.\",\"startDate\":\"2022-01-01\",\"endDate\":\"2023-12-31\",\"isCurrent\":false,\"gallery\":[],\"logo\":null},{\"id\":\"bkjalr4mjtleyqska8fv8b4z\",\"category\":\"organization\",\"organization\":\"Educare CSUI\",\"initials\":\"EC\",\"role\":\"Staff of Job Fair\",\"dateRange\":\"'22–'23\",\"description\":\"Served in the Job Fair division of Educare CSUI, a career-related event at the Faculty of Computer Science, Universitas Indonesia. Responsibilities included reaching out to HR representatives, collecting and curating job opportunities for the event, and supporting operational execution during the job fair sessions.\",\"startDate\":\"2022-01-01\",\"endDate\":\"2023-06-01\",\"isCurrent\":false,\"gallery\":[],\"logo\":null},{\"id\":\"kns0oy84mt4aqzlntfo0t46p\",\"category\":\"organization\",\"organization\":\"BEM Faculty of Computer Science, Universitas Indonesia\",\"initials\":\"BFC\",\"role\":\"Staff of Knowledge and Academic Affairs Division\",\"dateRange\":\"'22\",\"description\":\"Contributed to the faculty student executive board in the knowledge and academic affairs division. This experience strengthened my ability to work in structured student organizations, communicate ideas, and support programs related to academic and intellectual development.\",\"startDate\":\"2022-01-01\",\"endDate\":\"2022-12-31\",\"isCurrent\":false,\"gallery\":[],\"logo\":null},{\"id\":\"ivffli7kcl7xa2uuyl9d3b3k\",\"category\":\"organization\",\"organization\":\"Teladan Robotic Team\",\"initials\":\"TRT\",\"role\":\"Secretary / Member\",\"dateRange\":\"'18–'20\",\"description\":\"Joined the school robotics extracurricular community, gaining early exposure to technology, problem solving, teamwork, and engineering-oriented thinking.\",\"startDate\":\"2018-07-01\",\"endDate\":\"2020-06-30\",\"isCurrent\":false,\"gallery\":[],\"logo\":null}],\"others\":[]}}]\nd:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0g3rov4w115o0.js\",\"async\":true}]\ne:[\"$\",\"$L10\",null,{\"children\":[\"$\",\"$11\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@12\"}]}]\n12:null\n","/about":"1:I[39756,[\"/_next/static/chunks/2miu-xgxthh4m.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"LoadingBoundaryProvider\"]\n2:I[40306,[\"/_next/static/chunks/2miu-xgxthh4m.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/0pxxjzjfwu9d_.js\"],\"Delayed\"]\n3:\"$Sreact.fragment\"\n4:I[39756,[\"/_next/static/chunks/2miu-xgxthh4m.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n5:I[37457,[\"/_next/static/chunks/2miu-xgxthh4m.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n6:[]\n0:{\"rsc\":[\"$\",\"$L1\",null,{\"loading\":[[\"$\",\"main\",\"l\",{\"className\":\"relative z-[3] mx-auto w-full max-w-[820px] px-[22px] pt-28 pb-16 sm:pt-32\",\"children\":[\"$\",\"$L2\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"skeleton\",\"style\":{\"height\":44,\"width\":240,\"borderRadius\":10}}],[\"$\",\"div\",null,{\"className\":\"skeleton mt-4\",\"style\":{\"height\":16,\"maxWidth\":560,\"borderRadius\":8}}],[\"$\",\"div\",null,{\"className\":\"skeleton mt-7\",\"style\":{\"aspectRatio\":\"16 / 9\",\"borderRadius\":15}}],[\"$\",\"div\",null,{\"className\":\"mt-8 flex flex-col gap-3\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"skeleton\",\"style\":{\"height\":15,\"width\":\"100%\",\"borderRadius\":6}}],[\"$\",\"div\",\"1\",{\"className\":\"skeleton\",\"style\":{\"height\":15,\"width\":\"100%\",\"borderRadius\":6}}],[